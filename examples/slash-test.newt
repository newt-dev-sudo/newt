bot name "SlashTest"
bot prefix "!"
bot token from env "DISCORD_TOKEN"

on slash "greet":
  say with components "Click a button!":
    button "approve" label "Approve"
    button "reject" label "Reject"

on button click "approve":
  reply "You clicked approve!"

on button click "reject":
  reply "You clicked reject!"

on select menu "role_select":
  reply "You selected: {values.join(', ')}"
