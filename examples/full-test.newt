bot name "FullTest"
bot prefix "!"
bot token from env "DISCORD_TOKEN"

on ready:
    set activity "Testing all features"

# Test reply statement
on command "test-reply":
    reply "This is a reply test"

# Test say statement
on command "test-say":
    say "This is a say test"

# Test let statement and variables
on command "test-let":
    let greeting = "Hello"
    reply "{greeting}, {user.username}!"

# Test store and load statements
on command "test-store":
    let current = load user.id points or 0
    store user.id points = current + 100
    reply "Data stored"

on command "test-load":
    let data = load user.id points or 0
    reply "Loaded: {data}"

# Test if statement
on command "test-if":
    let points = load user.id points or 0
    if points > 0:
        reply "You have points"
    else:
        reply "No points yet"

# Test REST method - getUser
on command "test-getuser":
    try:
        let userInfo = getUser(target.id)
        reply "User: {userInfo.username}"
    on error:
        reply "Mention a user first"

# Test REST method - getGuild
on command "test-getguild":
    try:
        let guildInfo = getGuild(server.id)
        reply "Guild: {guildInfo.name}"
    on error:
        reply "Could not fetch guild"

# Test error handling
on command "test-error":
    try:
        let bad = getUser("invalid-id")
        reply "This should not show"
    on error:
        reply "Error caught successfully"

# Test set activity
on command "test-activity":
    set activity "Custom activity"
    reply "Activity set"

# Test fetch expression
on command "test-fetch":
    try:
        let data = fetch "https://httpbin.org/get"
        reply "Fetch successful"
    on error:
        reply "Fetch failed"

# Test message editing (skipped - requires message reference syntax)
# Test message deletion (skipped - requires message reference syntax)

# Test file upload
on command "test-upload":
    upload "./test.txt" with message "Here's a file"

# Test message update handler
on message update:
    reply "I noticed you edited a message!"

# Test message delete handler
on message delete:
    say "I noticed a message was deleted!"

# Test join handler
on join:
    say "Welcome to the server, {user.username}!" in channel "testing"

# Test leave handler
on leave:
    say "Goodbye, {user.username}!" in channel "testing"

# Test give role
on command "test-giverole":
    give target role "Member"
    reply "Gave Member role"

# Test remove role
on command "test-removerole":
    remove target role "Member"
    reply "Removed Member role"

# Test mute
on command "test-mute":
    mute target for 1 minute
    reply "Muted for 1 minute"

# Test kick
on command "test-kick":
    kick target
    reply "Kicked user"

# Test ban
on command "test-ban":
    ban target
    reply "Banned user"

# Test say embed
on command "test-embed":
    say embed:
        title "Test Embed"
        description "This is a test embed"
        color #5865F2
        field "Field 1" "Value 1"
        field "Field 2" "Value 2"

# Test say with components
on command "test-components":
    say with components "Click the button":
        button "test-btn" label "Click Me"
