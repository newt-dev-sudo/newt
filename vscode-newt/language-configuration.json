{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "[",
      "close": "]"
    }
  ],
  "surroundingPairs": [
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "(",
      "close": ")"
    }
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^`~!@$%^&*()+=[\\]{}\\\\|;:'\",<>/?\\s]+)",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(on\\s+.*|if\\s+.*|else|for\\s+each\\s+.*|try|on\\s+error|every\\s+.*|at\\s+.*|say\\s+embed):\\s*(#.*)?$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*.*:\\s*$",
      "action": {
        "indent": "indent"
      }
    }
  ]
}
