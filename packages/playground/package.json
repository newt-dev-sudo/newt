    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.14"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT"
}
