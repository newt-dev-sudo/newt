{
  "name": "@newt-lang/playground",
  "version": "0.1.0",
  "private": true,
  "description": "Browser playground and simulated Discord UI for Newt.",
  "type": "module",
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json && vite build",
    "dev": "vite --host 127.0.0.1",
