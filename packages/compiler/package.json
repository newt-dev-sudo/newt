  "keywords": [
    "discord",
    "bot",
    "dsl",
    "compiler",
    "newt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/newt-lang/newt.git",
    "directory": "packages/compiler"
  },
  "homepage": "https://github.com/newt-lang/newt#readme",
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT"
}
